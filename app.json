{
  "expo": {
    "name": "moamoa",
    "slug": "moamoa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "moamoa",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A4568"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.csj1430.moamoa"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A4568"
      },
      "package": "com.csj1430.moamoa"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "560d36cf1c622ef8182eeb5053a10355",
          "kakaoAppKeyScheme": "kakao560d36cf1c622ef8182eeb5053a10355",
          "overrideKakaoSDKVersion": "2.8.6",
          "kotlinVersion": "1.5.10"
        }
      ]
    ]
  }
}
